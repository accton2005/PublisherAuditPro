STRIPE_SECRET_KEY=""

# PayPal Payment Gateway API Credentials
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET_KEY=""
PAYPAL_MODE="sandbox"

# Paddle Payment Gateway API Credentials
PADDLE_VENDOR_ID=""
PADDLE_API_KEY=""
PADDLE_MODE="sandbox"
